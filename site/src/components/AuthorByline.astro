---
interface Props {
  author?: string;
  date?: string;
  readingTime?: string;
  updated?: string;
}

const {
  author = 'Parvez Ahmed',
  date,
  readingTime,
  updated,
} = Astro.props;

const formatDate = (d?: string) => {
  if (!d) return null;
  const dt = new Date(d);
  if (isNaN(dt.getTime())) return d;
  return dt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};

const publishedFmt = formatDate(date);
const updatedFmt = formatDate(updated);
---

<div class="author-byline">
  <img src="/profile_pic.jpeg" alt={author} class="byline-avatar" width="32" height="32" />
  <div class="byline-meta">
    <a href="/about/" class="byline-name">{author}</a>
    <div class="byline-sub">
      {publishedFmt && <time datetime={date}>{publishedFmt}</time>}
      {updatedFmt && <span>· Updated {updatedFmt}</span>}
      {readingTime && <span>· {readingTime}</span>}
    </div>
  </div>
</div>

<style>
  .author-byline {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    margin: 0 0 1rem;
    border-bottom: 1px solid var(--sl-color-hairline);
  }
  .byline-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    object-fit: cover;
  }
  .byline-meta {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .byline-name {
    font-weight: 600;
    color: var(--sl-color-white);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .byline-name:hover { text-decoration: underline; }
  .byline-sub {
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
  }
</style>
