---
/**
 * AffiliateLink — Wraps a link with affiliate/UTM attribution.
 *
 * Usage:
 *   <AffiliateLink tool="semrush" campaign="best-of-2026">Try Semrush</AffiliateLink>
 *   <AffiliateLink href="https://example.com">Custom URL</AffiliateLink>
 *
 * Reads canonical URLs from src/data/affiliates.json so a single edit
 * propagates everywhere. Adds UTM params and rel="sponsored nofollow"
 * (FTC + Google requirement for affiliate links).
 */

import affiliates from '../data/affiliates.json';

interface Props {
  tool?: string;
  href?: string;
  campaign?: string;
  class?: string;
}

const { tool, href: rawHref, campaign = 'general', class: className } = Astro.props;

let resolvedHref = rawHref;
if (tool) {
  const entry = (affiliates as Record<string, { url: string }>)[tool];
  if (entry) resolvedHref = entry.url;
}

if (!resolvedHref) {
  throw new Error(`AffiliateLink requires either 'tool' (in affiliates.json) or 'href'. Got tool=${tool}`);
}

const url = new URL(resolvedHref);
url.searchParams.set('ref', 'agentguides');
url.searchParams.set('utm_source', 'agentguides.dev');
url.searchParams.set('utm_medium', 'review');
url.searchParams.set('utm_campaign', campaign);

const finalHref = url.toString();
---

<a href={finalHref} class={`affiliate-link ${className ?? ''}`} target="_blank" rel="sponsored nofollow noopener">
  <slot />
</a>

<style>
  .affiliate-link {
    color: var(--sl-color-accent);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-style: dotted;
  }
  .affiliate-link:hover {
    text-decoration-style: solid;
  }
</style>
