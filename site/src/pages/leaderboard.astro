---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import modelsData from '../data/models.json';
const { last_updated, models, benchmark_registry } = modelsData as any;

// Schema v2: every cell carries {value, source, url}. There is deliberately no
// composite score. Vendors publish only the benchmarks that flatter them —
// Anthropic reports HLE (~54 avg) and skips GPQA (~91 avg), Google does the
// reverse — so averaging across whatever each lab happened to publish ranks
// publication strategy, not capability. Per-benchmark tables only.

// Sources whose figures may be both scored and published. `estimate` and
// `unsourced_legacy` are displayed but never ranked.
const RANKABLE_SOURCES = new Set(['vendor', 'swebench', 'lmarena', 'artificial_analysis']);

// Benchmarks still actively reported in 2026, in display order.
const LIVE_KEYS = Object.keys(benchmark_registry).filter(
  (k) => benchmark_registry[k].status === 'live'
);
const LEGACY_KEYS = Object.keys(benchmark_registry).filter(
  (k) => benchmark_registry[k].status === 'legacy'
);

// Gaps below this are not resolvable — SWE-bench reports to 0.1 on a
// 500-problem set where one problem is worth 0.2. Rendered as ties.
const NOISE_FLOOR = 1.0;

const enriched = models.map((m: any) => {
  const cells: Record<string, any> = {};
  const flat: Record<string, number> = {};   // plain numbers for charts/calculator
  let sourced = 0;

  for (const [key, cell] of Object.entries((m.benchmarks || {}) as Record<string, any>)) {
    if (!cell || cell.value == null) continue;
    const rankable = RANKABLE_SOURCES.has(cell.source);
    const live = benchmark_registry[key]?.status === 'live';
    cells[key] = {
      value: cell.value,
      source: cell.source,
      url: cell.url || null,
      note: cell.note || null,
      rankable,
      estimated: cell.source === 'estimate',
      unsourced: cell.source === 'unsourced_legacy',
    };
    if (rankable) {
      flat[key] = cell.value;
      if (live) sourced += 1;
    }
  }

  const blended = m.pricing?.input != null && m.pricing?.output != null
    ? (m.pricing.input * 0.75) + (m.pricing.output * 0.25)
    : null;

  return { ...m, cells, benchmarks: flat, blended, sourced };
});

// Default ordering: SWE-bench Pro has the widest vendor coverage of any live
// benchmark, so it is the most complete single ranking we can honestly show.
const DEFAULT_BENCH = 'swe_bench_pro';
enriched.sort((a: any, b: any) =>
  (b.benchmarks[DEFAULT_BENCH] ?? -1) - (a.benchmarks[DEFAULT_BENCH] ?? -1));

const rankedCount = enriched.filter((m: any) => m.status === 'current').length;
const sourcedCells = enriched.reduce(
  (n: number, m: any) => n + Object.values(m.cells).filter((c: any) => c.rankable).length, 0);

const vendors = Array.from(new Set(enriched.map((m: any) => m.vendor))).sort();

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Dataset",
      "@id": "https://agentguides.dev/leaderboard/#dataset",
      "name": "AI Models Leaderboard — Benchmarks, Pricing, and Sources",
      "description": `Comparison of ${enriched.length} AI models across currently-reported benchmarks (GPQA Diamond, SWE-bench Verified, SWE-bench Pro, Terminal-Bench 2.1, HLE, MMMU-Pro), pricing per million tokens, and context windows. Every benchmark cell cites its source; estimated and unsourced figures are marked and excluded from all rankings.`,
      "url": "https://agentguides.dev/leaderboard/",
      "dateModified": last_updated,
      "inLanguage": "en-US",
      "creator": { "@type": "Person", "name": "Parvez Ahmed", "url": "https://github.com/Sero01" },
      "publisher": { "@type": "Person", "name": "Parvez Ahmed", "url": "https://agentguides.dev/about/" },
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "keywords": "AI models leaderboard, LLM benchmark comparison, AI model pricing, SWE-bench Pro, Terminal-Bench 2.1, GPQA Diamond, HLE, benchmark provenance",
      "variableMeasured": [
        "GPQA Diamond","SWE-bench Verified","SWE-bench Pro","Terminal-Bench 2.1","HLE","MMMU-Pro","Input price per million tokens","Output price per million tokens","Context window","Throughput tokens per second","Benchmark source"
      ]
    },
    {
      "@type": "WebPage",
      "@id": "https://agentguides.dev/leaderboard/#webpage",
      "url": "https://agentguides.dev/leaderboard/",
      "name": `AI Models Leaderboard — Benchmarks, Pricing, and Comparison (${last_updated})`,
      "description": `Interactive leaderboard comparing ${enriched.length} AI models on benchmarks, pricing, context windows, and throughput. Updated ${last_updated}.`,
      "inLanguage": "en-US",
      "isPartOf": { "@type": "WebSite", "name": "AI Agents Guide", "url": "https://agentguides.dev" },
      "primaryImageOfPage": "https://agentguides.dev/og/leaderboard.png",
      "dateModified": last_updated,
      "author": { "@type": "Person", "name": "Parvez Ahmed", "url": "https://github.com/Sero01" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://agentguides.dev/" },
        { "@type": "ListItem", "position": 2, "name": "Leaderboard", "item": "https://agentguides.dev/leaderboard/" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Why is there no single overall score?", "acceptedAnswer": { "@type": "Answer", "text": "Because vendors publish only the benchmarks that flatter them. Anthropic reports HLE, where frontier models average about 54, and does not report GPQA Diamond, where they average about 91. Google and Alibaba do the reverse. Averaging whatever each lab happened to publish ranks publication strategy rather than capability — in our own testing it moved models by up to six places. We show per-benchmark tables instead and link to Artificial Analysis and LiveBench for overall composites." } },
        { "@type": "Question", "name": "How do you decide which benchmark numbers to trust?", "acceptedAnswer": { "@type": "Answer", "text": "Every cell records its source and a link. Only figures from a vendor model card, a system card, or an open leaderboard are ranked. Estimates and figures inherited without recorded provenance are shown greyed out and excluded from every ranking. A build-time validator rejects any number that has no attributable source, so an unsourced figure cannot reach the site." } },
        { "@type": "Question", "name": "Why do some models show tied ranks?", "acceptedAnswer": { "@type": "Answer", "text": "Gaps smaller than one point are not resolvable. SWE-bench reports to one decimal place on a 500-problem set, where a single problem is worth 0.2 points, so a 0.1 difference is noise. Models within one point share a rank rather than being ordered arbitrarily." } },
        { "@type": "Question", "name": "Which benchmark is the most predictive for AI coding tools?", "acceptedAnswer": { "@type": "Answer", "text": "SWE-bench Pro and Terminal-Bench 2.1. SWE-bench Verified is still useful but is increasingly saturated at the frontier, and SWE-bench Pro is designed to resist memorisation. Note that Pro scores run roughly 20 points below Verified on the same model, so the two are never comparable." } },
        { "@type": "Question", "name": "Why are some benchmarks greyed out?", "acceptedAnswer": { "@type": "Answer", "text": "They have been retired or superseded. MATH-500 and AIME were dropped from active reporting, tau-squared bench was replaced by tau-cubed Banking, Terminal-Bench Hard and 2.0 were replaced by 2.1, HumanEval is saturated, and the Aider Polyglot leaderboard is unmaintained. Retired columns are kept visible for historical reference but never contribute to a ranking." } }
      ]
    }
  ]
});

const pageDescription = `Interactive leaderboard comparing ${enriched.length} AI models on benchmarks (MMLU-Pro, GPQA, SWE-bench, MATH-500, MMMU, Aider, tau-bench), pricing, context windows, and throughput. Updated ${last_updated}.`;

const head = [
  { tag: 'title' as const, content: `AI Models Leaderboard — Benchmarks, Pricing, and Comparison (${last_updated})` },
  { tag: 'meta' as const, attrs: { property: 'og:title', content: 'AI Models Leaderboard — Benchmarks, Pricing, and Comparison' } },
  { tag: 'meta' as const, attrs: { property: 'og:description', content: `Compare ${enriched.length} AI models on benchmarks, pricing, and context. Interactive table, charts, and cost calculator. Updated ${last_updated}.` } },
  { tag: 'meta' as const, attrs: { property: 'og:type', content: 'website' } },
  { tag: 'meta' as const, attrs: { property: 'og:url', content: 'https://agentguides.dev/leaderboard/' } },
  { tag: 'meta' as const, attrs: { property: 'og:image', content: 'https://agentguides.dev/og/leaderboard.png' } },
  { tag: 'meta' as const, attrs: { name: 'twitter:title', content: 'AI Models Leaderboard — Benchmarks, Pricing, Comparison' } },
  { tag: 'meta' as const, attrs: { name: 'twitter:description', content: `Sortable table of ${enriched.length} AI models with benchmarks, pricing, and a cost calculator. Updated ${last_updated}.` } },
  { tag: 'meta' as const, attrs: { name: 'twitter:image', content: 'https://agentguides.dev/og/leaderboard.png' } },
  { tag: 'meta' as const, attrs: { name: 'keywords', content: 'AI models leaderboard, LLM benchmark comparison, MMLU-Pro, GPQA, SWE-bench, AI model pricing, Claude Fable 5, Claude Opus 4.8, Claude Sonnet 5, GPT-5.6, GPT-5.6 Sol, GPT-5.6 Terra, GPT-5.6 Luna, GPT-5.5, Gemini 3.1, Grok 4.5, Grok 4.3, Microsoft MAI, MAI-Thinking-1, Kimi K3, Kimi K2.7, Inkling, Thinking Machines, GLM-5.2, open weights coding model, AI model context window' } },
  { tag: 'script' as const, attrs: { type: 'application/ld+json' }, content: jsonLd },
];
---

<StarlightPage
  frontmatter={{
    title: 'AI Models Leaderboard',
    description: pageDescription,
    tableOfContents: false,
    head,
  }}
>
  <div id="leaderboard-app">
    <p class="updated-pill">Updated {last_updated} · {enriched.length} models · {sourcedCells} sourced benchmark figures</p>
    <p class="lead">Compare {enriched.length} large language models on the benchmarks vendors actually report in 2026, with pricing, context window, and throughput. <strong>Every figure links to its source.</strong> Estimates and inherited numbers are greyed out and never ranked.</p>

    <div class="notice">
      <p><strong>There is no single "best model" score here, on purpose.</strong> Labs publish only the benchmarks that flatter them — Anthropic reports HLE (frontier average ≈54) and skips GPQA Diamond (≈91); Google and Alibaba do the reverse. Averaging across whatever each lab chose to publish ranks publication strategy, not capability: when we tested it, models moved by up to six places depending on which benchmarks they happened to report. Rank on the benchmark that matches your workload, or see <a href="https://artificialanalysis.ai/leaderboards/models" target="_blank" rel="noopener">Artificial Analysis</a> and <a href="https://livebench.ai" target="_blank" rel="noopener">LiveBench</a> for independently-run composites.</p>
    </div>

    <div class="filters">
      <div class="filter-group">
        <span class="filter-label">Status</span>
        <span class="chip active" data-status="current">Current</span>
        <span class="chip" data-status="all">Include superseded</span>
      </div>
      <div class="filter-group">
        <span class="filter-label">License</span>
        <span class="chip active" data-license="all">All</span>
        <span class="chip" data-license="open">Open</span>
        <span class="chip" data-license="closed">Closed</span>
      </div>
      <div class="filter-group">
        <span class="filter-label">Context</span>
        <span class="chip active" data-ctx="all">All</span>
        <span class="chip" data-ctx="32000">≥ 32K</span>
        <span class="chip" data-ctx="128000">≥ 128K</span>
        <span class="chip" data-ctx="200000">≥ 200K</span>
        <span class="chip" data-ctx="1000000">≥ 1M</span>
      </div>
      <div class="filter-group">
        <span class="filter-label">Search</span>
        <input type="text" id="search-input" class="search-input" placeholder="Model or vendor…" />
      </div>
    </div>

    <div class="table-wrap">
      <table id="leaderboard-table">
        <thead>
          <tr>
            <th data-sort="name">Model</th>
            <th data-sort="vendor">Vendor</th>
            <th data-sort="sourced" title="Number of currently-reported benchmarks with a cited source">Src</th>
            <th data-sort="context_window">Ctx</th>
            <th data-sort="pricing.input">In $/M</th>
            <th data-sort="pricing.output">Out $/M</th>
            <th data-sort="benchmarks.gpqa_diamond">GPQA</th>
            <th data-sort="benchmarks.swe_bench_verified">SWE-V</th>
            <th data-sort="benchmarks.swe_bench_pro">SWE-Pro</th>
            <th data-sort="benchmarks.terminal_bench_2_1">TB 2.1</th>
            <th data-sort="benchmarks.hle">HLE</th>
          </tr>
        </thead>
        <tbody id="leaderboard-body"></tbody>
      </table>
    </div>

    <div class="charts-row">
      <div class="chart-card">
        <h2>Benchmark Leaders</h2>
        <select id="bench-select">
          <option value="swe_bench_pro">SWE-bench Pro (real coding, memorisation-resistant)</option>
          <option value="terminal_bench_2_1">Terminal-Bench 2.1 (agentic terminal use)</option>
          <option value="gpqa_diamond">GPQA Diamond (science reasoning)</option>
          <option value="swe_bench_verified">SWE-bench Verified (real coding)</option>
          <option value="hle">HLE (frontier reasoning)</option>
          <option value="mmmu_pro">MMMU-Pro (multimodal)</option>
        </select>
        <p class="chart-note">Models within {NOISE_FLOOR} point share a rank — sub-point gaps are below measurement noise. Only sourced figures appear.</p>
        <div id="bar-chart"></div>
      </div>
      <div class="chart-card">
        <h2>Price vs Performance</h2>
        <p class="chart-note">X: blended $/M (log). Y: score on the benchmark selected at left. Pareto-optimal models are highlighted.</p>
        <div id="scatter-chart"></div>
      </div>
    </div>

    <div class="calc">
      <h2>Cost Calculator</h2>
      <div class="calc-grid">
        <div>
          <label for="calc-model">Model</label>
          <select id="calc-model"></select>
        </div>
        <div>
          <label for="calc-input-tokens">Input tokens / request</label>
          <input type="number" id="calc-input-tokens" value="3000" min="0" />
        </div>
        <div>
          <label for="calc-output-tokens">Output tokens / request</label>
          <input type="number" id="calc-output-tokens" value="800" min="0" />
        </div>
        <div>
          <label for="calc-requests">Requests / month</label>
          <input type="number" id="calc-requests" value="10000" min="0" />
        </div>
      </div>
      <div id="calc-output" class="calc-result"></div>
      <p class="calc-note">
        Track real spend per provider with <a href="https://www.helicone.ai/?ref=agentguides&utm_source=agentguides.dev&utm_campaign=leaderboard" rel="sponsored nofollow noopener" target="_blank">Helicone</a> or <a href="https://langfuse.com/?ref=agentguides&utm_source=agentguides.dev&utm_campaign=leaderboard" rel="sponsored nofollow noopener" target="_blank">Langfuse</a>. Need access to every model under one bill? <a href="https://openrouter.ai/?ref=agentguides&utm_source=agentguides.dev&utm_campaign=leaderboard" rel="sponsored nofollow noopener" target="_blank">OpenRouter</a> routes to all of them.
      </p>
    </div>

    <div class="prose">
      <h2>How to read this leaderboard</h2>
      <p><strong>Every number links to where it came from.</strong> A figure is only ranked if it comes from a vendor model card, a system card, or an open leaderboard. Numbers marked <em>est</em> are estimates, numbers marked <em>?</em> were inherited without recorded provenance, and neither ever contributes to a ranking or a chart. The <strong>Src</strong> column counts how many currently-reported benchmarks a model has a citable source for — a low number means the vendor published little, not that the model is weak.</p>
      <p><strong>Ranks are assigned in tiers.</strong> Models within one point share a rank. SWE-bench reports to one decimal on a 500-problem set where a single problem is worth 0.2 points, so a 0.1 gap is noise. Ordering two models on that difference would imply a precision the benchmark does not have.</p>
      <p><strong>Never compare SWE-bench Verified against SWE-bench Pro.</strong> They are different benchmarks and Pro runs roughly 20 points lower on the same model — Claude Opus 4.8 scores 69.2 on Pro and 88.6 on Verified. They get separate columns here for that reason. The same applies to Terminal-Bench 2.0 versus 2.1.</p>
      <p>The blended price column is a 3:1 input-to-output weighted average, which approximates the cost shape of most production agent workloads (heavy input from context and history, smaller output per call). Prompt caching changes this calculus substantially — Anthropic and OpenAI both ship aggressive caching that can drop effective price by 60-80% on repeated-context workloads. If your application is conversational or RAG-heavy, the cached-read price is the one you should optimise against, not the headline input price.</p>

      <h2>Which benchmark actually matters</h2>
      <p><strong>SWE-bench Pro</strong> measures end-to-end issue resolution on real repositories, built to resist the memorisation that has begun to inflate SWE-bench Verified. Currently the widest-reported coding benchmark and the most predictive single number for AI coding tools.</p>
      <p><strong>Terminal-Bench 2.1</strong> measures agentic work in a real terminal — multi-step tasks with tool use and recovery from failure. Now the headline agentic eval for most labs, and it replaced Terminal-Bench Hard and 2.0, which are not comparable to it.</p>
      <p><strong>GPQA Diamond</strong> measures graduate-level science reasoning on questions verified to be hard for non-experts. Still the best indicator of novel reasoning over retrieved facts, though frontier models now cluster above 90, so it is beginning to saturate.</p>
      <p><strong>SWE-bench Verified</strong> measures issue resolution on real GitHub repositories. Still widely quoted, but frontier scores now sit in the high 70s to 90s and the spread between good models has narrowed considerably.</p>
      <p><strong>HLE (Humanity's Last Exam)</strong> is the hardest benchmark in general use — frontier models score in the 40s and 50s. Check whether a quoted figure was run with tools, since that shifts results by roughly 5-15 points.</p>
      <p><strong>MMMU-Pro</strong> measures multimodal reasoning across images and text, and is a harder variant of the original MMMU. Only matters if your application uses vision.</p>

      <h2>Benchmarks we no longer rank</h2>
      <p>Several benchmarks that used to appear here have been retired or superseded, and are kept as greyed-out columns for historical reference only. <strong>MATH-500</strong> and <strong>AIME</strong> were dropped from active reporting. <strong>τ²-Bench</strong> was replaced by τ³-Banking. <strong>Terminal-Bench Hard</strong> and <strong>2.0</strong> were replaced by 2.1. <strong>HumanEval</strong> is saturated — every frontier model scores 92-96, so it separates nothing. The <strong>Aider Polyglot</strong> leaderboard is unmaintained; its top entry is still GPT-5 and it tracks no model released in 2026. <strong>MMLU-Pro</strong> and <strong>MMMU</strong> remain in use but have been dropped from the major composite indices.</p>
      <p>This churn is the main reason benchmark tables go stale. A table that keeps demanding numbers the industry stopped publishing will either sit empty or get filled with guesses.</p>

      <h2>Picking a model for production</h2>
      <p>Three rules of thumb after spending the past 12 months testing most models on this list in production-shaped workloads:</p>
      <p><strong>1. Start cheaper, upgrade only on observed regression.</strong> Most agent flows do not need a frontier model. We default to Claude Sonnet 4.6 or DeepSeek V3.1 and only move to Opus / GPT-5 / o3 when we see a quality cliff. The cost difference compounds fast at production volume.</p>
      <p><strong>2. Optimise for cached-read price, not headline price.</strong> If your workload has any repeated context (system prompts, conversation history, RAG corpora), the cached-read price column dominates monthly spend. Anthropic and OpenAI both offer caching; Google's flash variants have implicit caching as well.</p>
      <p><strong>3. Benchmark your own task before committing.</strong> Run the cheapest plausible candidate on 30 examples of your real task. The leaderboard tells you which models to consider; only your eval set tells you which model to ship.</p>

      <h2>Methodology and sources</h2>
      <p>Benchmark figures come from vendor model cards and system cards, and from <a href="https://www.swebench.com" target="_blank" rel="noopener">SWE-bench</a>. Each cell stores its own source URL and the date it was read; scores are frozen at that date rather than silently recomputed later. A build-time validator rejects any figure that lacks an attributable source, so an unsourced number cannot reach this page — and it rejects figures sourced to secondary summary sites, several of which publish benchmark scores that appear in no vendor release.</p>
      <p>Vendor-reported figures are self-run and are labelled as such on hover. We cross-check our orderings against <a href="https://artificialanalysis.ai/leaderboards/models" target="_blank" rel="noopener">Artificial Analysis</a> and <a href="https://livebench.ai" target="_blank" rel="noopener">LiveBench</a>, both of which run their own independent evaluations and publish composite indices. Their numbers are not reproduced here — for an independently-measured overall ranking, go to the source.</p>
      <p>Pricing is taken from each provider's first-party API on {last_updated}; open-weights pricing reflects the typical OpenRouter / Together / Fireworks rate. Models are marked <em>superseded</em> when a newer model exists in the same series and <em>unreleased</em> when announced without public availability; neither is ranked by default.</p>
      <p>For the long-form analysis behind these numbers — which models we use day-to-day, which we ruled out, and how the landscape shifted in the last six months — read the companion post <a href="/best/llm-benchmark-comparison-2026/">LLM Benchmark Comparison 2026</a>.</p>
    </div>

    <div id="compare-bar"><span id="compare-count">0</span> selected · Compare →</div>
    <aside id="compare-drawer">
      <button class="close" aria-label="Close compare">×</button>
      <h2>Compare</h2>
      <div id="compare-content"></div>
    </aside>
  </div>
</StarlightPage>

<style is:global>
  /* Widen the Starlight content column for this page only (TOC is disabled). */
  :root:has(#leaderboard-app) {
    --sl-content-width: min(1560px, 100%);
  }

  #leaderboard-app {
    /* Vars consumed by the JS-generated SVG scatter chart */
    --open: var(--accent);
    --closed: var(--text-muted);
    --accent-high: var(--accent-hover);
    --text: var(--text-secondary);
  }

  #leaderboard-app .updated-pill {
    font-family: var(--mono); font-size: 0.7rem;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--accent);
  }
  #leaderboard-app .lead {
    max-width: 720px;
  }

  /* ── Filters ───────────────────────────────────────────────── */
  #leaderboard-app .filters {
    display: flex; flex-wrap: wrap; gap: 0.75rem 1.25rem;
    padding: 1.5rem 0; align-items: center;
    border-bottom: 1px solid var(--border);
    margin: 0 0 2rem;
  }
  #leaderboard-app .filter-group { display: flex; gap: 0.4rem; align-items: center; margin-top: 0; }
  #leaderboard-app .filter-label {
    font-family: var(--mono); font-size: 0.65rem; font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase; letter-spacing: 0.15em;
    margin-right: 0.5rem;
  }
  #leaderboard-app .chip {
    font-family: var(--mono); font-size: 0.72rem;
    letter-spacing: 0.05em; text-transform: lowercase;
    background: transparent; border: 1px solid var(--accent-dim);
    color: var(--text-secondary);
    padding: 0.4rem 0.75rem; border-radius: 2px;
    cursor: pointer; user-select: none;
    transition: all 0.3s ease;
    margin-top: 0;
  }
  #leaderboard-app .chip:hover { background: var(--accent-dim); border-color: var(--accent); color: var(--text-primary); }
  #leaderboard-app .chip.active { background: var(--accent); color: var(--bg); border-color: var(--accent); }
  #leaderboard-app .search-input {
    font-family: var(--sans); font-weight: 300;
    background: var(--bg-card); border: 1px solid var(--border);
    color: var(--text-primary); border-radius: 2px;
    padding: 0.5rem 0.75rem; font-size: 0.9rem; min-width: 220px;
    transition: border-color 0.3s ease;
    margin-top: 0;
  }
  #leaderboard-app .search-input:focus { outline: none; border-color: var(--accent); }
  #leaderboard-app .search-input::placeholder { color: var(--text-muted); }

  /* ── Table ─────────────────────────────────────────────────── */
  #leaderboard-app .table-wrap {
    overflow: auto;
    border: 1px solid var(--border);
    margin-bottom: 3rem; max-height: 640px;
    background: var(--bg-card);
  }
  #leaderboard-app table { display: table; width: 100%; border-collapse: collapse; font-size: 0.9rem; margin: 0; border: none; }
  #leaderboard-app thead { position: sticky; top: 0; z-index: 1; }
  #leaderboard-app th {
    font-family: var(--mono); font-size: 0.7rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--text-muted);
    text-align: left; padding: 1rem 0.9rem;
    cursor: pointer; user-select: none;
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
    background: var(--bg-card-hover);
    white-space: nowrap;
    transition: color 0.3s ease;
  }
  #leaderboard-app th:last-child, #leaderboard-app td:last-child { border-right: none; }
  #leaderboard-app th:hover { color: var(--accent); }
  #leaderboard-app th .sort-indicator { color: var(--accent); font-size: 0.7rem; margin-left: 0.25rem; }

  /* ── Cell provenance ─────────────────────────────────────────────────────
     A number's visual weight tracks how well it is attributed. Sourced
     figures read as data; estimates and inherited values are visibly
     demoted so they cannot be mistaken for measurements. */
  #leaderboard-app td.cell-src a {
    color: inherit; text-decoration: none;
    border-bottom: 1px dotted color-mix(in srgb, var(--accent) 60%, transparent);
