  #leaderboard-app #compare-drawer.open { transform: translateX(0); }
  #leaderboard-app #compare-drawer h2 {
    font-family: var(--serif); font-weight: 400;
    font-size: 2rem; color: var(--text-primary); margin: 0;
  }
  #leaderboard-app #compare-drawer .close {
    float: right; background: none; border: none;
    color: var(--text-muted); font-size: 1.75rem;
    cursor: pointer; line-height: 1;
    transition: color 0.3s ease;
  }
  #leaderboard-app #compare-drawer .close:hover { color: var(--accent); }
  #leaderboard-app .compare-table { width: 100%; margin-top: 1.5rem; border-collapse: collapse; font-size: 0.85rem; border: 1px solid var(--border); }
  #leaderboard-app .compare-table th, #leaderboard-app .compare-table td {
    padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--border);
    text-align: left; font-family: var(--sans); font-weight: 300;
  }
  #leaderboard-app .compare-table th {
    font-family: var(--mono); font-size: 0.7rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-muted); background: var(--bg-card);
    cursor: default; white-space: normal;
  }
  #leaderboard-app .compare-table th:first-child, #leaderboard-app .compare-table td:first-child { color: var(--text-muted); font-weight: 500; }

  /* ── Prose ─────────────────────────────────────────────────── */
  #leaderboard-app .prose { max-width: 760px; margin: 4rem 0 2rem; }
</style>

<script is:inline define:vars={{ MODELS: enriched, LAST_UPDATED: last_updated, REGISTRY: benchmark_registry, NOISE: NOISE_FLOOR, DEFAULT_BENCH }}>
  window.__LEADERBOARD = {
    models: MODELS, lastUpdated: LAST_UPDATED,
    registry: REGISTRY, noise: NOISE, defaultBench: DEFAULT_BENCH,
  };
</script>

<script is:inline>
  const REGISTRY = window.__LEADERBOARD.registry;
  const NOISE_FLOOR = window.__LEADERBOARD.noise;

  const STATE = {
    models: window.__LEADERBOARD.models,
    sort: { key: 'benchmarks.' + window.__LEADERBOARD.defaultBench, dir: 'desc' },
    filters: { license: 'all', ctx: 'all', search: '', status: 'current' },
    selected: new Set(),
  };

  const $ = (sel) => document.querySelector(sel);
  const $$ = (sel) => document.querySelectorAll(sel);

  function getValue(obj, path) {
    return path.split('.').reduce((o, k) => (o == null ? null : o[k]), obj);
  }

  function fmtPrice(n) { return n == null ? '—' : '$' + n.toFixed(2); }
  function fmtCtx(n) {
    if (!n) return '—';
    if (n >= 1000000) return (n / 1000000).toFixed(n % 1000000 === 0 ? 0 : 1) + 'M';
    if (n >= 1000) return (n / 1000).toFixed(n % 1000 === 0 ? 0 : 0) + 'K';
    return String(n);
  }
  function fmtScore(n) { return n == null ? '—' : Number(n).toFixed(1); }

  function applyFilters(list) {
    const { license, ctx, search, status } = STATE.filters;
    return list.filter(m => {
      if (status === 'current' && m.status !== 'current') return false;
      if (license !== 'all' && m.license !== license) return false;
      if (ctx !== 'all' && (m.context_window || 0) < Number(ctx)) return false;
      if (search) {
        const q = search.toLowerCase();
        if (!m.name.toLowerCase().includes(q) && !m.vendor.toLowerCase().includes(q)) return false;
      }
      return true;
    });
  }

  // Renders one benchmark cell with its provenance. A number that cannot be
  // attributed is never shown as if it were measured.
  function cellHtml(m, key) {
    const c = m.cells?.[key];
    if (!c) return '<td class="cell-none">—</td>';
    const v = Number(c.value).toFixed(1);

    if (c.estimated) {
      return `<td class="cell-est" title="Estimated, not a published measurement. Excluded from all rankings.">~${v}<span class="prov">est</span></td>`;
    }
    if (c.unsourced) {
      return `<td class="cell-unsourced" title="Inherited without recorded provenance. Excluded from all rankings.">${v}<span class="prov">?</span></td>`;
    }
    const label = c.source === 'vendor' ? 'vendor-reported' : c.source;
    const tip = (c.note ? c.note + ' — ' : '') + label;
    return c.url
      ? `<td class="cell-src"><a href="${c.url}" target="_blank" rel="noopener" title="${tip}">${v}</a></td>`
      : `<td class="cell-src" title="${tip}">${v}</td>`;
  }

  const STATUS_BADGE = {
    superseded: '<span class="badge badge-old" title="A newer model in the same series exists">superseded</span>',
    historical: '<span class="badge badge-old" title="Retained for reference only">historical</span>',
    unreleased: '<span class="badge badge-unreleased" title="Announced but never publicly released; no first-party API">unreleased</span>',
  };

  function applySort(list) {
    const { key, dir } = STATE.sort;
    const factor = dir === 'asc' ? 1 : -1;
    return [...list].sort((a, b) => {
      const av = getValue(a, key);
      const bv = getValue(b, key);
      if (av == null && bv == null) return 0;
      if (av == null) return 1;
      if (bv == null) return -1;
      if (typeof av === 'string') return factor * av.localeCompare(bv);
      return factor * (av - bv);
    });
  }

  function renderTable() {
    const filtered = applyFilters(STATE.models);
    const sorted = applySort(filtered);
    const tbody = $('#leaderboard-body');
    tbody.innerHTML = sorted.map(m => `
      <tr class="${m.status !== 'current' ? 'row-old' : ''}">
        <td><strong>${m.name}</strong> ${STATUS_BADGE[m.status] || ''}</td>
        <td><span class="vendor-chip">${m.vendor}</span></td>
        <td class="src-count" title="${m.sourced} of ${Object.keys(REGISTRY).filter(k => REGISTRY[k].status === 'live').length} currently-reported benchmarks have a cited source">${m.sourced}</td>
        <td>${fmtCtx(m.context_window)}</td>
        <td>${fmtPrice(m.pricing?.input)}</td>
        <td>${fmtPrice(m.pricing?.output)}</td>
        ${cellHtml(m, 'gpqa_diamond')}
        ${cellHtml(m, 'swe_bench_verified')}
        ${cellHtml(m, 'swe_bench_pro')}
        ${cellHtml(m, 'terminal_bench_2_1')}
        ${cellHtml(m, 'hle')}
      </tr>
    `).join('');
    // update sort indicators
    $$('#leaderboard-table th[data-sort]').forEach(th => {
      const k = th.getAttribute('data-sort');
      const ind = th.querySelector('.sort-indicator');
      if (ind) ind.remove();
      if (k === STATE.sort.key) {
        const span = document.createElement('span');
        span.className = 'sort-indicator';
        span.textContent = STATE.sort.dir === 'asc' ? ' ▲' : ' ▼';
        th.appendChild(span);
      }
    });
    bindCheckboxes();
  }

  function tryLink(m) {
    const router = m.license === 'open'
      ? 'https://openrouter.ai/?ref=agentguides&utm_source=agentguides.dev&utm_campaign=leaderboard-try'
      : 'https://openrouter.ai/?ref=agentguides&utm_source=agentguides.dev&utm_campaign=leaderboard-try';
    return `<a href="${router}" target="_blank" rel="sponsored nofollow noopener" class="try-btn">Try</a>`;
  }

  function bindCheckboxes() {
    $$('.compare-cb').forEach(cb => {
      cb.onchange = () => {
        const id = cb.getAttribute('data-id');
        if (cb.checked) {
          if (STATE.selected.size >= 4) {
            cb.checked = false;
            alert('Compare up to 4 models at a time.');
            return;
          }
          STATE.selected.add(id);
        } else {
          STATE.selected.delete(id);
        }
        updateCompareBar();
      };
    });
  }

  function updateCompareBar() {
    const bar = $('#compare-bar');
    const count = STATE.selected.size;
    $('#compare-count').textContent = String(count);
    bar.style.display = count >= 2 ? 'block' : 'none';
  }

  $('#compare-bar').onclick = () => {
    const drawer = $('#compare-drawer');
    const content = $('#compare-content');
    const selected = STATE.models.filter(m => STATE.selected.has(m.id));
    if (selected.length < 2) return;
    const rows = [
      ['Vendor', selected.map(m => m.vendor)],
      ['License', selected.map(m => m.license)],
      ['Context', selected.map(m => fmtCtx(m.context_window))],
      ['Input $/M', selected.map(m => fmtPrice(m.pricing?.input))],
      ['Output $/M', selected.map(m => fmtPrice(m.pricing?.output))],
      ['Blended $/M', selected.map(m => fmtPrice(m.blended))],
      ['Status', selected.map(m => m.status)],
      ['Sourced benchmarks', selected.map(m => `<strong>${m.sourced}</strong>`)],
    ];
    // One row per currently-reported benchmark, sourced figures only.
    for (const [key, spec] of Object.entries(REGISTRY)) {
      if (spec.status !== 'live') continue;
      if (!selected.some(m => m.benchmarks?.[key] != null)) continue;
      rows.push([spec.label, selected.map(m => fmtScore(m.benchmarks?.[key]))]);
    }
    content.innerHTML = `
      <table class="compare-table">
        <thead><tr><th></th>${selected.map(m => `<th>${m.name}</th>`).join('')}</tr></thead>
        <tbody>${rows.map(([label, vals]) => `<tr><th>${label}</th>${vals.map(v => `<td>${v}</td>`).join('')}</tr>`).join('')}</tbody>
      </table>
    `;
    drawer.classList.add('open');
  };
  $('#compare-drawer .close').onclick = () => $('#compare-drawer').classList.remove('open');

  // Header sort
  $$('#leaderboard-table th[data-sort]').forEach(th => {
    th.onclick = () => {
      const k = th.getAttribute('data-sort');
      if (STATE.sort.key === k) {
        STATE.sort.dir = STATE.sort.dir === 'desc' ? 'asc' : 'desc';
      } else {
        STATE.sort.key = k;
        STATE.sort.dir = 'desc';
      }
      renderTable();
    };
  });

  // Filter chips
  $$('.chip[data-license]').forEach(c => {
    c.onclick = () => {
      $$('.chip[data-license]').forEach(x => x.classList.remove('active'));
      c.classList.add('active');
      STATE.filters.license = c.getAttribute('data-license');
      renderTable(); renderBarChart(); renderScatter();
    };
  });
  $$('.chip[data-ctx]').forEach(c => {
    c.onclick = () => {
      $$('.chip[data-ctx]').forEach(x => x.classList.remove('active'));
      c.classList.add('active');
      STATE.filters.ctx = c.getAttribute('data-ctx');
      renderTable();
    };
  });
  $$('.chip[data-status]').forEach(c => {
    c.onclick = () => {
      $$('.chip[data-status]').forEach(x => x.classList.remove('active'));
      c.classList.add('active');
      STATE.filters.status = c.getAttribute('data-status');
      renderTable(); renderBarChart(); renderScatter();
    };
  });
  $('#search-input').oninput = (e) => {
    STATE.filters.search = e.target.value;
    renderTable();
  };

  // Bar chart. Ranks are assigned in tiers: models whose scores fall within
  // NOISE_FLOOR of the tier leader share a rank. Ordering models by a 0.1
  // difference implies a precision the benchmarks do not have — SWE-bench
  // reports to 0.1 on a 500-problem set where one problem is worth 0.2.
  function rankTiers(list, key) {
    const sorted = [...list].sort((a, b) => b.benchmarks[key] - a.benchmarks[key]);
    let rank = 0, tierLead = null;
    return sorted.map((m, i) => {
      const v = m.benchmarks[key];
      if (tierLead === null || (tierLead - v) >= NOISE_FLOOR) {
        tierLead = v;
        rank = i + 1;
      }
      return { model: m, value: v, rank };
    });
  }

  function renderBarChart() {
    const key = $('#bench-select').value;
    // Only sourced figures are ranked; estimates and inherited values are
    // absent from m.benchmarks by construction.
    const eligible = applyFilters(STATE.models).filter(m => m.benchmarks?.[key] != null);
    if (!eligible.length) {
      $('#bar-chart').innerHTML =
        `<p class="empty-note">No model has a sourced ${REGISTRY[key]?.label || key} figure yet.</p>`;
      return;
    }
    const rows = rankTiers(eligible, key).slice(0, 15);
    const max = Math.max(...rows.map(r => r.value));
    let prevRank = null;
    $('#bar-chart').innerHTML = rows.map(r => {
      const tied = r.rank === prevRank;
      prevRank = r.rank;
      const pct = (r.value / max) * 100;
      return `
        <div class="bar-row">
          <span class="bar-rank ${tied ? 'tied' : ''}" title="${tied ? 'Tied — within ' + NOISE_FLOOR + ' point of the model above' : ''}">${tied ? '=' : r.rank}</span>
          <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${r.model.name}</span>
          <div class="bar-track"><div class="bar-fill ${r.model.license}" style="width:${pct}%"></div></div>
          <span style="text-align:right">${r.value.toFixed(1)}</span>
        </div>
      `;
    }).join('');
  }
  $('#bench-select').onchange = () => { renderBarChart(); renderScatter(); };

  // Scatter chart (SVG)
  function renderScatter() {
    const key = $('#bench-select').value;
    const pts = applyFilters(STATE.models)
      .filter(m => m.blended != null && m.benchmarks?.[key] != null && m.blended > 0)
      .map(m => ({ x: Math.log10(m.blended + 0.01), y: m.benchmarks[key], name: m.name, license: m.license, blended: m.blended }));
    if (pts.length === 0) { $('#scatter-chart').innerHTML = '<p>No data.</p>'; return; }
    const W = 560, H = 360, P = 40;
    const xMin = Math.min(...pts.map(p => p.x));
    const xMax = Math.max(...pts.map(p => p.x));
    const yMin = Math.min(...pts.map(p => p.y));
    const yMax = Math.max(...pts.map(p => p.y));
    const sx = (x) => P + ((x - xMin) / (xMax - xMin || 1)) * (W - 2 * P);
    const sy = (y) => H - P - ((y - yMin) / (yMax - yMin || 1)) * (H - 2 * P);

    // Pareto frontier: minimise price, maximise score
    const sortedByPrice = [...pts].sort((a, b) => a.x - b.x);
    const pareto = [];
    let bestY = -Infinity;
    for (const p of sortedByPrice) {
      if (p.y > bestY) { pareto.push(p); bestY = p.y; }
    }
    const paretoSet = new Set(pareto.map(p => p.name));

    const circles = pts.map(p => `
      <circle cx="${sx(p.x)}" cy="${sy(p.y)}" r="${paretoSet.has(p.name) ? 6 : 4}"
        fill="var(--${p.license})" opacity="${paretoSet.has(p.name) ? 1 : 0.6}"
        stroke="${paretoSet.has(p.name) ? 'var(--accent-high)' : 'none'}" stroke-width="2">
        <title>${p.name} — $${p.blended.toFixed(2)}/M, score ${p.y.toFixed(1)}</title>
      </circle>
    `).join('');

    const labels = pareto.map(p => `
      <text x="${sx(p.x) + 8}" y="${sy(p.y) - 6}" font-size="10" fill="var(--text)">${p.name}</text>
    `).join('');

    $('#scatter-chart').innerHTML = `
      <svg viewBox="0 0 ${W} ${H}" style="width:100%;height:auto;background:var(--bg);border-radius:0.375rem">
        <line x1="${P}" y1="${H - P}" x2="${W - P}" y2="${H - P}" stroke="var(--border)" />
        <line x1="${P}" y1="${P}" x2="${P}" y2="${H - P}" stroke="var(--border)" />
        <text x="${W / 2}" y="${H - 8}" text-anchor="middle" font-size="11" fill="var(--text-muted)">Blended price per 1M tokens (log10)</text>
        <text x="14" y="${H / 2}" transform="rotate(-90 14 ${H / 2})" text-anchor="middle" font-size="11" fill="var(--text-muted)">Composite score</text>
        ${circles}
        ${labels}
      </svg>
    `;
  }

  // Cost calculator
  function populateCalcModels() {
    const sel = $('#calc-model');
    sel.innerHTML = STATE.models.map(m => `<option value="${m.id}">${m.name} (${m.vendor})</option>`).join('');
  }
  function renderCalc() {
    const id = $('#calc-model').value;
    const m = STATE.models.find(x => x.id === id);
    if (!m) return;
    const inT = Number($('#calc-input-tokens').value) || 0;
    const outT = Number($('#calc-output-tokens').value) || 0;
    const reqs = Number($('#calc-requests').value) || 0;
    const inputCost = (inT * (m.pricing?.input ?? 0)) / 1e6;
    const outputCost = (outT * (m.pricing?.output ?? 0)) / 1e6;
    const perReq = inputCost + outputCost;
    const monthly = perReq * reqs;
    // Cheapest open / closed
    const cheapestOpen = [...STATE.models].filter(x => x.license === 'open' && x.blended != null).sort((a,b) => a.blended - b.blended)[0];
    const cheapestClosed = [...STATE.models].filter(x => x.license === 'closed' && x.blended != null).sort((a,b) => a.blended - b.blended)[0];
    const monthlyAlt = (model) => {
      if (!model) return 0;
      return ((inT * (model.pricing?.input ?? 0)) + (outT * (model.pricing?.output ?? 0))) / 1e6 * reqs;
    };
    $('#calc-output').innerHTML = `
      <div>Monthly cost on <strong>${m.name}</strong>: <strong>$${monthly.toFixed(2)}</strong></div>
      <div style="margin-top:0.5rem;font-size:0.88rem;color:var(--text-muted)">
        Per request: $${perReq.toFixed(5)} ·
        vs cheapest open (${cheapestOpen?.name}): $${monthlyAlt(cheapestOpen).toFixed(2)} ·
        vs cheapest closed (${cheapestClosed?.name}): $${monthlyAlt(cheapestClosed).toFixed(2)}
      </div>
    `;
  }
  ['calc-model','calc-input-tokens','calc-output-tokens','calc-requests'].forEach(id => {
    document.getElementById(id).addEventListener('input', renderCalc);
    document.getElementById(id).addEventListener('change', renderCalc);
  });

  // Init
  renderTable();
  renderBarChart();
  renderScatter();
  populateCalcModels();
  renderCalc();
</script>
