---
import modelsData from '../data/models.json';
const { last_updated, models } = modelsData as any;

// Compute composite score (mean of normalised benchmarks, 0-100) and blended price (3:1 input:output)
const BENCHMARK_KEYS = ['mmlu_pro','gpqa_diamond','humaneval','swe_bench','math_500','mmmu','aider_polyglot','tau_bench'];

const enriched = models.map((m: any) => {
  const scores = BENCHMARK_KEYS.map(k => m.benchmarks?.[k]).filter((v: any) => typeof v === 'number');
  const composite = scores.length ? scores.reduce((a: number, b: number) => a + b, 0) / scores.length : null;
  const blended = m.pricing?.input != null && m.pricing?.output != null
    ? (m.pricing.input * 0.75) + (m.pricing.output * 0.25)
    : null;
  return { ...m, composite, blended };
});

// Sort default by composite desc
enriched.sort((a: any, b: any) => (b.composite ?? -1) - (a.composite ?? -1));

const vendors = Array.from(new Set(enriched.map((m: any) => m.vendor))).sort();
---

