<script is:inline>
  const STATE = {
    models: window.__LEADERBOARD.models,
    sort: { key: 'composite', dir: 'desc' },
    filters: { license: 'all', ctx: 'all', search: '' },
    selected: new Set(),
  };

  const $ = (sel) => document.querySelector(sel);
  const $$ = (sel) => document.querySelectorAll(sel);

  function getValue(obj, path) {
    return path.split('.').reduce((o, k) => (o == null ? null : o[k]), obj);
  }

  function fmtPrice(n) { return n == null ? '—' : '$' + n.toFixed(2); }
  function fmtCtx(n) {
    if (!n) return '—';
    if (n >= 1000000) return (n / 1000000).toFixed(n % 1000000 === 0 ? 0 : 1) + 'M';
    if (n >= 1000) return (n / 1000).toFixed(n % 1000 === 0 ? 0 : 0) + 'K';
    return String(n);
  }
  function fmtScore(n) { return n == null ? '—' : Number(n).toFixed(1); }

  function applyFilters(list) {
    const { license, ctx, search } = STATE.filters;
    return list.filter(m => {
      if (license !== 'all' && m.license !== license) return false;
      if (ctx !== 'all' && (m.context_window || 0) < Number(ctx)) return false;
      if (search) {
        const q = search.toLowerCase();
        if (!m.name.toLowerCase().includes(q) && !m.vendor.toLowerCase().includes(q)) return false;
      }
      return true;
    });
  }

  function applySort(list) {
    const { key, dir } = STATE.sort;
    const factor = dir === 'asc' ? 1 : -1;
    return [...list].sort((a, b) => {
      const av = getValue(a, key);
      const bv = getValue(b, key);
      if (av == null && bv == null) return 0;
      if (av == null) return 1;
      if (bv == null) return -1;
      if (typeof av === 'string') return factor * av.localeCompare(bv);
      return factor * (av - bv);
    });
  }

  function renderTable() {
    const filtered = applyFilters(STATE.models);
    const sorted = applySort(filtered);
    const tbody = $('#leaderboard-body');
    tbody.innerHTML = sorted.map(m => `
      <tr>
        <td><strong>${m.name}</strong></td>
        <td><span class="vendor-chip">${m.vendor}</span></td>
        <td><strong>${fmtScore(m.composite)}</strong></td>
        <td>${fmtCtx(m.context_window)}</td>
        <td>${fmtPrice(m.pricing?.input)}</td>
        <td>${fmtPrice(m.pricing?.output)}</td>
        <td>${fmtScore(m.benchmarks?.mmlu_pro)}</td>
        <td>${fmtScore(m.benchmarks?.gpqa_diamond)}</td>
        <td>${fmtScore(m.benchmarks?.swe_bench)}</td>
      </tr>
    `).join('');
    // update sort indicators
    $$('#leaderboard-table th[data-sort]').forEach(th => {
      const k = th.getAttribute('data-sort');
      const ind = th.querySelector('.sort-indicator');
      if (ind) ind.remove();
      if (k === STATE.sort.key) {
        const span = document.createElement('span');
        span.className = 'sort-indicator';
        span.textContent = STATE.sort.dir === 'asc' ? ' ▲' : ' ▼';
        th.appendChild(span);
      }
    });
    bindCheckboxes();
  }

  function tryLink(m) {
    const router = m.license === 'open'
      ? 'https://openrouter.ai/?ref=agentguides&utm_source=agentguides.dev&utm_campaign=leaderboard-try'
      : 'https://openrouter.ai/?ref=agentguides&utm_source=agentguides.dev&utm_campaign=leaderboard-try';
    return `<a href="${router}" target="_blank" rel="sponsored nofollow noopener" class="try-btn">Try</a>`;
  }

  function bindCheckboxes() {
    $$('.compare-cb').forEach(cb => {
      cb.onchange = () => {
        const id = cb.getAttribute('data-id');
        if (cb.checked) {
          if (STATE.selected.size >= 4) {
            cb.checked = false;
            alert('Compare up to 4 models at a time.');
            return;
          }
          STATE.selected.add(id);
        } else {
          STATE.selected.delete(id);
        }
        updateCompareBar();
      };
    });
  }

  function updateCompareBar() {
    const bar = $('#compare-bar');
    const count = STATE.selected.size;
    $('#compare-count').textContent = String(count);
    bar.style.display = count >= 2 ? 'block' : 'none';
  }

  $('#compare-bar').onclick = () => {
    const drawer = $('#compare-drawer');
    const content = $('#compare-content');
    const selected = STATE.models.filter(m => STATE.selected.has(m.id));
    if (selected.length < 2) return;
    const rows = [
      ['Vendor', selected.map(m => m.vendor)],
      ['License', selected.map(m => m.license)],
      ['Context', selected.map(m => fmtCtx(m.context_window))],
      ['Input $/M', selected.map(m => fmtPrice(m.pricing?.input))],
      ['Output $/M', selected.map(m => fmtPrice(m.pricing?.output))],
      ['Blended $/M', selected.map(m => fmtPrice(m.blended))],
      ['MMLU-Pro', selected.map(m => fmtScore(m.benchmarks?.mmlu_pro))],
      ['GPQA Diamond', selected.map(m => fmtScore(m.benchmarks?.gpqa_diamond))],
      ['HumanEval', selected.map(m => fmtScore(m.benchmarks?.humaneval))],
      ['SWE-bench', selected.map(m => fmtScore(m.benchmarks?.swe_bench))],
      ['MATH-500', selected.map(m => fmtScore(m.benchmarks?.math_500))],
      ['MMMU', selected.map(m => fmtScore(m.benchmarks?.mmmu))],
      ['Aider Polyglot', selected.map(m => fmtScore(m.benchmarks?.aider_polyglot))],
      ['tau-bench', selected.map(m => fmtScore(m.benchmarks?.tau_bench))],
      ['Composite', selected.map(m => `<strong>${fmtScore(m.composite)}</strong>`)],
    ];
    content.innerHTML = `
      <table class="compare-table">
        <thead><tr><th></th>${selected.map(m => `<th>${m.name}</th>`).join('')}</tr></thead>
        <tbody>${rows.map(([label, vals]) => `<tr><th>${label}</th>${vals.map(v => `<td>${v}</td>`).join('')}</tr>`).join('')}</tbody>
      </table>
    `;
    drawer.classList.add('open');
  };
  $('#compare-drawer .close').onclick = () => $('#compare-drawer').classList.remove('open');

  // Header sort
  $$('#leaderboard-table th[data-sort]').forEach(th => {
    th.onclick = () => {
      const k = th.getAttribute('data-sort');
      if (STATE.sort.key === k) {
        STATE.sort.dir = STATE.sort.dir === 'desc' ? 'asc' : 'desc';
      } else {
        STATE.sort.key = k;
        STATE.sort.dir = 'desc';
      }
      renderTable();
    };
  });

  // Filter chips
  $$('.chip[data-license]').forEach(c => {
    c.onclick = () => {
      $$('.chip[data-license]').forEach(x => x.classList.remove('active'));
      c.classList.add('active');
      STATE.filters.license = c.getAttribute('data-license');
      renderTable();
    };
  });
  $$('.chip[data-ctx]').forEach(c => {
    c.onclick = () => {
      $$('.chip[data-ctx]').forEach(x => x.classList.remove('active'));
      c.classList.add('active');
      STATE.filters.ctx = c.getAttribute('data-ctx');
      renderTable();
    };
  });
  $('#search-input').oninput = (e) => {
    STATE.filters.search = e.target.value;
    renderTable();
  };

  // Bar chart
  function renderBarChart() {
    const key = $('#bench-select').value;
    const top = [...STATE.models]
      .filter(m => m.benchmarks?.[key] != null)
      .sort((a, b) => b.benchmarks[key] - a.benchmarks[key])
      .slice(0, 15);
    const max = Math.max(...top.map(m => m.benchmarks[key]));
    $('#bar-chart').innerHTML = top.map(m => {
      const pct = (m.benchmarks[key] / max) * 100;
      return `
        <div class="bar-row">
          <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${m.name}</span>
          <div class="bar-track"><div class="bar-fill ${m.license}" style="width:${pct}%"></div></div>
          <span style="text-align:right">${m.benchmarks[key].toFixed(1)}</span>
        </div>
      `;
    }).join('');
  }
  $('#bench-select').onchange = renderBarChart;

  // Scatter chart (SVG)
  function renderScatter() {
    const pts = STATE.models
      .filter(m => m.blended != null && m.composite != null && m.blended > 0)
      .map(m => ({ x: Math.log10(m.blended + 0.01), y: m.composite, name: m.name, license: m.license, blended: m.blended }));
    if (pts.length === 0) { $('#scatter-chart').innerHTML = '<p>No data.</p>'; return; }
    const W = 560, H = 360, P = 40;
    const xMin = Math.min(...pts.map(p => p.x));
    const xMax = Math.max(...pts.map(p => p.x));
    const yMin = Math.min(...pts.map(p => p.y));
    const yMax = Math.max(...pts.map(p => p.y));
    const sx = (x) => P + ((x - xMin) / (xMax - xMin || 1)) * (W - 2 * P);
    const sy = (y) => H - P - ((y - yMin) / (yMax - yMin || 1)) * (H - 2 * P);

    // Pareto frontier: minimise price, maximise score
    const sortedByPrice = [...pts].sort((a, b) => a.x - b.x);
    const pareto = [];
    let bestY = -Infinity;
    for (const p of sortedByPrice) {
      if (p.y > bestY) { pareto.push(p); bestY = p.y; }
    }
    const paretoSet = new Set(pareto.map(p => p.name));

    const circles = pts.map(p => `
      <circle cx="${sx(p.x)}" cy="${sy(p.y)}" r="${paretoSet.has(p.name) ? 6 : 4}"
        fill="var(--${p.license})" opacity="${paretoSet.has(p.name) ? 1 : 0.6}"
        stroke="${paretoSet.has(p.name) ? 'var(--accent-high)' : 'none'}" stroke-width="2">
        <title>${p.name} — $${p.blended.toFixed(2)}/M, score ${p.y.toFixed(1)}</title>
      </circle>
    `).join('');

    const labels = pareto.map(p => `
      <text x="${sx(p.x) + 8}" y="${sy(p.y) - 6}" font-size="10" fill="var(--text)">${p.name}</text>
    `).join('');

    $('#scatter-chart').innerHTML = `
      <svg viewBox="0 0 ${W} ${H}" style="width:100%;height:auto;background:var(--bg);border-radius:0.375rem">
        <line x1="${P}" y1="${H - P}" x2="${W - P}" y2="${H - P}" stroke="var(--border)" />
        <line x1="${P}" y1="${P}" x2="${P}" y2="${H - P}" stroke="var(--border)" />
        <text x="${W / 2}" y="${H - 8}" text-anchor="middle" font-size="11" fill="var(--text-muted)">Blended price per 1M tokens (log10)</text>
        <text x="14" y="${H / 2}" transform="rotate(-90 14 ${H / 2})" text-anchor="middle" font-size="11" fill="var(--text-muted)">Composite score</text>
        ${circles}
        ${labels}
      </svg>
    `;
  }

  // Cost calculator
  function populateCalcModels() {
    const sel = $('#calc-model');
    sel.innerHTML = STATE.models.map(m => `<option value="${m.id}">${m.name} (${m.vendor})</option>`).join('');
  }
  function renderCalc() {
    const id = $('#calc-model').value;
    const m = STATE.models.find(x => x.id === id);
    if (!m) return;
    const inT = Number($('#calc-input-tokens').value) || 0;
    const outT = Number($('#calc-output-tokens').value) || 0;
    const reqs = Number($('#calc-requests').value) || 0;
    const inputCost = (inT * (m.pricing?.input ?? 0)) / 1e6;
    const outputCost = (outT * (m.pricing?.output ?? 0)) / 1e6;
    const perReq = inputCost + outputCost;
    const monthly = perReq * reqs;
    // Cheapest open / closed
    const cheapestOpen = [...STATE.models].filter(x => x.license === 'open' && x.blended != null).sort((a,b) => a.blended - b.blended)[0];
    const cheapestClosed = [...STATE.models].filter(x => x.license === 'closed' && x.blended != null).sort((a,b) => a.blended - b.blended)[0];
    const monthlyAlt = (model) => {
      if (!model) return 0;
      return ((inT * (model.pricing?.input ?? 0)) + (outT * (model.pricing?.output ?? 0))) / 1e6 * reqs;
    };
    $('#calc-output').innerHTML = `
      <div>Monthly cost on <strong>${m.name}</strong>: <strong>$${monthly.toFixed(2)}</strong></div>
      <div style="margin-top:0.5rem;font-size:0.88rem;color:var(--text-muted)">
        Per request: $${perReq.toFixed(5)} ·
        vs cheapest open (${cheapestOpen?.name}): $${monthlyAlt(cheapestOpen).toFixed(2)} ·
        vs cheapest closed (${cheapestClosed?.name}): $${monthlyAlt(cheapestClosed).toFixed(2)}
      </div>
    `;
  }
  ['calc-model','calc-input-tokens','calc-output-tokens','calc-requests'].forEach(id => {
    document.getElementById(id).addEventListener('input', renderCalc);
    document.getElementById(id).addEventListener('change', renderCalc);
  });

  // Theme toggle (shared key with Starlight & homepage)
  const themeBtn = document.getElementById('theme-toggle');
  if (themeBtn) {
    themeBtn.addEventListener('click', () => {
      const stored = localStorage.getItem('starlight-theme');
      const cur = (stored === 'dark' || stored === 'light')
        ? stored
        : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      const next = cur === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      try { localStorage.setItem('starlight-theme', next); } catch (e) {}
    });
  }

  // Init
  renderTable();
  renderBarChart();
  renderScatter();
  populateCalcModels();
  renderCalc();
</script>

</body>
</html>
