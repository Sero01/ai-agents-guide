      :root:not([data-theme='light']) .theme-toggle .icon-moon { display: none; }
    }
    @media (max-width: 768px) {
      .nav-links, .nav-github { display: none; }
      .nav-inner { padding: 1rem 1.25rem; }
    }

    /* ── Hero ──────────────────────────────────────────────────── */
    .hero { padding: 5rem 0 3rem; border-bottom: 1px solid var(--border); }
    .hero h1 {
      font-family: var(--serif); font-weight: 400;
      font-size: clamp(2.5rem, 5vw, 4rem);
      line-height: 1.1; letter-spacing: -0.03em;
      color: var(--text-primary); margin-bottom: 1.25rem;
    }
    .hero p {
      font-family: var(--sans); font-weight: 300;
      color: var(--text-secondary); max-width: 720px;
      font-size: 1.05rem; line-height: 1.8;
    }
    .updated-pill {
      display: inline-block;
      font-family: var(--mono); font-size: 0.7rem;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 1.5rem;
    }

    /* ── Filters ───────────────────────────────────────────────── */
