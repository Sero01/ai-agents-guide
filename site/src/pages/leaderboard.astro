    transition: all 0.3s ease;
  }
  #leaderboard-app .try-btn:hover { background: var(--accent-hover); border-color: var(--accent-hover); transform: translateY(-1px); }
  #leaderboard-app .compare-cb { width: 16px; height: 16px; cursor: pointer; accent-color: var(--accent); }

  /* ── Charts ────────────────────────────────────────────────── */
  #leaderboard-app .charts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; margin-bottom: 3rem; background: var(--border); border: 1px solid var(--border); }
  @media (max-width: 900px) { #leaderboard-app .charts-row { grid-template-columns: 1fr; } }
  #leaderboard-app .chart-card { background: var(--bg-card); padding: 1.75rem; margin-top: 0; }
  #leaderboard-app .chart-card h2 {
    font-family: var(--serif); font-weight: 400;
    font-size: 1.5rem; line-height: 1.3;
    color: var(--text-primary); margin: 0 0 1rem;
  }
  #leaderboard-app .chart-card p { font-family: var(--sans); font-weight: 300; color: var(--text-muted); }
  #leaderboard-app .chart-card .chart-note { font-size: 0.85rem; color: var(--text-muted); margin: 0 0 0.5rem; }
  #leaderboard-app .chart-card select {
    font-family: var(--mono); font-size: 0.78rem;
    background: var(--bg); border: 1px solid var(--border);
    color: var(--text-primary); border-radius: 2px;
    padding: 0.4rem 0.65rem; margin: 0 0 1rem;
    cursor: pointer;
  }
  #leaderboard-app .chart-card select:focus { outline: none; border-color: var(--accent); }

  #leaderboard-app .bar-row { display: grid; grid-template-columns: 11rem 1fr 3rem; align-items: center; gap: 0.6rem; padding: 0.3rem 0; font-size: 0.8rem; font-family: var(--sans); color: var(--text-secondary); margin-top: 0; }
  #leaderboard-app .bar-track { height: 10px; background: var(--bg); border: 1px solid var(--border); overflow: hidden; }
  #leaderboard-app .bar-fill { height: 100%; }
  #leaderboard-app .bar-fill.open { background: var(--accent); }
  #leaderboard-app .bar-fill.closed { background: var(--text-muted); }

  /* ── Cost calculator ───────────────────────────────────────── */
  #leaderboard-app .calc {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 2rem; margin-bottom: 3rem;
  }
  #leaderboard-app .calc h2 {
    font-family: var(--serif); font-weight: 400;
    font-size: 1.8rem; line-height: 1.2;
    color: var(--text-primary); margin: 0 0 1.5rem;
  }
  #leaderboard-app .calc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 1.25rem; margin: 0 0 1.5rem; }
  #leaderboard-app .calc-grid label {
    font-family: var(--mono); font-size: 0.65rem; font-weight: 500;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--text-muted);
    display: block; margin-bottom: 0.5rem;
