    td strong { font-family: var(--serif); font-weight: 500; font-size: 1.05rem; color: var(--text-primary); }
    tr:hover td { background: var(--bg-card-hover); }
    .vendor-chip { font-family: var(--mono); font-size: 0.7rem; color: var(--text-muted); letter-spacing: 0.05em; }
    .lic-open { color: var(--accent); font-weight: 500; font-size: 0.72rem; font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.1em; }
    .lic-closed { color: var(--text-muted); font-weight: 500; font-size: 0.72rem; font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.1em; }
    .try-btn {
      font-family: var(--sans); font-size: 0.72rem; font-weight: 500;
      letter-spacing: 0.08em; text-transform: uppercase;
      display: inline-block; padding: 0.35rem 0.8rem; border-radius: 2px;
      background: var(--accent); color: var(--bg);
      border: 1px solid var(--accent);
      transition: all 0.3s ease;
    }
    .try-btn:hover { background: var(--accent-hover); border-color: var(--accent-hover); transform: translateY(-1px); }
    .compare-cb { width: 16px; height: 16px; cursor: pointer; accent-color: var(--accent); }

    /* ── Charts ────────────────────────────────────────────────── */
    .charts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; margin-bottom: 3rem; background: var(--border); border: 1px solid var(--border); }
    @media (max-width: 900px) { .charts-row { grid-template-columns: 1fr; } }
    .chart-card { background: var(--bg-card); padding: 1.75rem; }
    .chart-card h2 {
      font-family: var(--serif); font-weight: 400;
      font-size: 1.5rem; line-height: 1.3;
      color: var(--text-primary); margin-bottom: 1rem;
    }
    .chart-card p { font-family: var(--sans); font-weight: 300; color: var(--text-muted); }
    .chart-card select {
      font-family: var(--mono); font-size: 0.78rem;
      background: var(--bg); border: 1px solid var(--border);
      color: var(--text-primary); border-radius: 2px;
      padding: 0.4rem 0.65rem; margin-bottom: 1rem;
      cursor: pointer;
    }
    .chart-card select:focus { outline: none; border-color: var(--accent); }

    .bar-row { display: grid; grid-template-columns: 11rem 1fr 3rem; align-items: center; gap: 0.6rem; padding: 0.3rem 0; font-size: 0.8rem; font-family: var(--sans); color: var(--text-secondary); }
    .bar-track { height: 10px; background: var(--bg); border: 1px solid var(--border); overflow: hidden; }
    .bar-fill { height: 100%; }
    .bar-fill.open { background: var(--accent); }
    .bar-fill.closed { background: var(--text-muted); }

    /* ── Cost calculator ───────────────────────────────────────── */
    .calc {
      background: var(--bg-card);
      border: 1px solid var(--border);
      padding: 2rem; margin-bottom: 3rem;
    }
    .calc h2 {
      font-family: var(--serif); font-weight: 400;
      font-size: 1.8rem; line-height: 1.2;
      color: var(--text-primary); margin-bottom: 1.5rem;
    }
    .calc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 1.25rem; margin-bottom: 1.5rem; }
    .calc-grid label {
      font-family: var(--mono); font-size: 0.65rem; font-weight: 500;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--text-muted);
      display: block; margin-bottom: 0.5rem;
    }
    .calc-grid input, .calc-grid select {
      font-family: var(--sans); font-weight: 300; font-size: 0.95rem;
      width: 100%; background: var(--bg);
      border: 1px solid var(--border); color: var(--text-primary);
      border-radius: 2px; padding: 0.55rem 0.7rem;
    }
    .calc-grid input:focus, .calc-grid select:focus { outline: none; border-color: var(--accent); }
    .calc-result {
      background: var(--bg); border: 1px solid var(--border);
      padding: 1.25rem; font-family: var(--sans); font-weight: 300;
      color: var(--text-secondary);
    }
    .calc-result strong {
      font-family: var(--serif); font-weight: 500;
      color: var(--accent); font-size: 1.75rem;
    }

    /* ── Compare drawer ────────────────────────────────────────── */
    #compare-bar {
      position: fixed; bottom: 1.25rem; left: 50%;
      transform: translateX(-50%);
      background: var(--accent); color: var(--bg);
      padding: 0.75rem 1.5rem; border-radius: 2px;
      font-family: var(--sans); font-weight: 500; font-size: 0.85rem;
      letter-spacing: 0.05em; text-transform: uppercase;
      cursor: pointer; display: none;
      border: 1px solid var(--accent);
      transition: all 0.3s ease;
    }
    #compare-bar:hover { background: var(--accent-hover); }
    #compare-drawer {
      position: fixed; top: 0; right: 0; bottom: 0;
      width: min(95%, 720px); background: var(--bg);
      border-left: 1px solid var(--border);
      padding: 2rem; overflow-y: auto;
      transform: translateX(100%);
      transition: transform 0.3s ease; z-index: 110;
    }
    #compare-drawer.open { transform: translateX(0); }
    #compare-drawer h2 {
      font-family: var(--serif); font-weight: 400;
      font-size: 2rem; color: var(--text-primary);
    }
    #compare-drawer .close {
      float: right; background: none; border: none;
      color: var(--text-muted); font-size: 1.75rem;
      cursor: pointer; line-height: 1;
      transition: color 0.3s ease;
    }
    #compare-drawer .close:hover { color: var(--accent); }
    .compare-table { width: 100%; margin-top: 1.5rem; border-collapse: collapse; font-size: 0.85rem; border: 1px solid var(--border); }
    .compare-table th, .compare-table td {
      padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--border);
      text-align: left; font-family: var(--sans); font-weight: 300;
    }
    .compare-table th {
      font-family: var(--mono); font-size: 0.7rem;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--text-muted); background: var(--bg-card);
    }
    .compare-table th:first-child, .compare-table td:first-child { color: var(--text-muted); font-weight: 500; }

    /* ── Prose ─────────────────────────────────────────────────── */
    .prose { max-width: 760px; margin: 4rem 0 5rem; }
    .prose h2 {
      font-family: var(--serif); font-weight: 400;
      font-size: clamp(1.8rem, 3vw, 2.4rem); line-height: 1.2;
      letter-spacing: -0.02em;
      color: var(--text-primary);
      margin: 3rem 0 1rem;
    }
    .prose h2:first-child { margin-top: 0; }
    .prose h3 { font-family: var(--serif); font-weight: 400; font-size: 1.4rem; color: var(--text-primary); margin: 2rem 0 0.75rem; }
    .prose p {
      font-family: var(--sans); font-weight: 300;
      color: var(--text-secondary); line-height: 1.85;
      margin-bottom: 1.25rem; font-size: 1.02rem;
    }
    .prose strong { font-weight: 500; color: var(--text-primary); }
    .prose a { color: var(--accent); }
    .prose a:hover { color: var(--accent-hover); text-decoration: underline; text-underline-offset: 3px; }

    /* ── Footer ────────────────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--border);
      padding: 2.5rem 0;
      font-family: var(--mono); font-size: 0.7rem;
      letter-spacing: 0.05em;
      color: var(--text-muted); text-align: center;
    }
    footer a { color: var(--text-muted); }
    footer a:hover { color: var(--accent); }
  </style>
</head>
