  #leaderboard-app .calc-grid input, #leaderboard-app .calc-grid select {
    font-family: var(--sans); font-weight: 300; font-size: 0.95rem;
    width: 100%; background: var(--bg);
    border: 1px solid var(--border); color: var(--text-primary);
    border-radius: 2px; padding: 0.55rem 0.7rem;
  }
  #leaderboard-app .calc-grid input:focus, #leaderboard-app .calc-grid select:focus { outline: none; border-color: var(--accent); }
  #leaderboard-app .calc-result {
    background: var(--bg); border: 1px solid var(--border);
    padding: 1.25rem; font-family: var(--sans); font-weight: 300;
    color: var(--text-secondary);
  }
  #leaderboard-app .calc-result strong {
    font-family: var(--serif); font-weight: 500;
    color: var(--accent); font-size: 1.75rem;
