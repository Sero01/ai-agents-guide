    z-index: 110;
  }
  #leaderboard-app #compare-bar:hover { background: var(--accent-hover); }
  #leaderboard-app #compare-drawer {
    position: fixed; top: 0; right: 0; bottom: 0;
    width: min(95%, 720px); background: var(--bg);
    border-left: 1px solid var(--border);
    padding: 2rem; overflow-y: auto;
    transform: translateX(100%);
    transition: transform 0.3s ease; z-index: 110;
