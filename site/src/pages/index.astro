  .hero h1 em {
    font-style: italic;
    color: var(--accent);
    font-weight: 500;
  }
  .hero-lede {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 3rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Scroll hint pulse */
  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    width: 1px;
    height: 3.5rem;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.8; }
  }
  @media (max-width: 768px) {
    .scroll-hint { display: none; }
    .hero { min-height: 90vh; padding-top: 8rem; }
    .hero h1 { font-size: 2.4rem; }
  }

  /* fade up on load (hero only) */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .fade-1, .fade-2, .fade-3, .fade-4 {
    opacity: 0;
    animation: fadeUp 0.8s ease forwards;
  }
  .fade-1 { animation-delay: 0.1s; }
  .fade-2 { animation-delay: 0.3s; }
  .fade-3 { animation-delay: 0.5s; }
  .fade-4 { animation-delay: 0.7s; }

  /* ── Shared typography utilities ────────────────────────────────── */
  .eyebrow {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .btn {
    display: inline-block;
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.875rem 1.75rem;
    border-radius: 2px;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--bg);
    border: 1px solid var(--accent);
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    border-color: var(--accent-hover);
    transform: translateY(-1px);
  }
  .btn-ghost {
    border: 1px solid var(--border);
    color: var(--text-secondary);
  }
  .btn-ghost:hover {
    border-color: var(--border-hover);
    color: var(--text-primary);
  }

  /* ── Sections ───────────────────────────────────────────────────── */
  .section {
    padding: var(--space-xl) 2rem;
    border-top: 1px solid var(--border);
  }
  .section-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .section-header {
    margin-bottom: var(--space-lg);
  }
  .section-header .eyebrow { display: block; margin-bottom: var(--space-md); }
  .section-header h2 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    max-width: 600px;
    margin-bottom: var(--space-sm);
  }
  .section-header .section-desc {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-secondary);
    max-width: 600px;
  }

  @media (max-width: 768px) {
    .section { padding: var(--space-lg) 1.25rem; }
  }

  /* ── Card grid (1px border = gap) ──────────────────────────────── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .card {
    background: var(--bg-card);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    color: inherit;
    transition: background 0.3s ease;
    position: relative;
    min-height: 220px;
  }
  .card:hover { background: var(--bg-card-hover); }
  .card-meta {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }
  .card-badge {
    color: var(--accent);
    border: 1px solid var(--accent-dim);
    padding: 0.1rem 0.5rem;
    border-radius: 2px;
  }
  .card h3 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.5rem;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }
  .card p {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
    flex-grow: 1;
  }
  .card-arrow {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 1.5rem;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .card:hover .card-arrow { opacity: 1; transform: translateX(0); }

  @media (max-width: 768px) {
    .card-grid { grid-template-columns: 1fr; }
  }

  /* ── Learning paths (split rows) ───────────────────────────────── */
  .paths {
    border: 1px solid var(--border);
  }
  .path-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    border-bottom: 1px solid var(--border);
    background: var(--bg-card);
    transition: background 0.3s ease;
  }
  .path-row:last-child { border-bottom: none; }
  .path-row:hover { background: var(--bg-card-hover); }

  .path-label {
    padding: 2rem;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
  }
  .path-label em {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 500;
    font-size: 1.4rem;
    color: var(--text-primary);
  }
  .path-label .path-tag {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .path-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .path-body p {
    font-family: var(--sans);
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .path-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .path-links a {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: lowercase;
    color: var(--text-secondary);
    border: 1px solid var(--accent-dim);
    padding: 0.4rem 0.75rem;
    transition: all 0.3s ease;
  }
  .path-links a:hover {
    background: var(--accent-dim);
    border-color: var(--accent);
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .path-row { grid-template-columns: 1fr; }
    .path-label { border-right: none; border-bottom: 1px solid var(--border); padding: 1.5rem; }
    .path-body { padding: 1.5rem; }
  }

  /* ── Prose / About ──────────────────────────────────────────────── */
  .prose p {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text-secondary);
    max-width: 720px;
    margin-bottom: 1.5rem;
  }
  .prose a { color: var(--accent); }
  .prose a:hover { color: var(--accent-hover); }
  .prose strong { font-weight: 500; color: var(--text-primary); }

  /* ── Sponsor ────────────────────────────────────────────────────── */
  .section.sponsor { padding-top: var(--space-lg); padding-bottom: var(--space-lg); }

  /* ── Footer ─────────────────────────────────────────────────────── */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: var(--space-lg) 2rem var(--space-md);
  }
  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }
  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 540px) {
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
  }

  .footer-author { display: flex; flex-direction: column; gap: 1rem; }
  .author-row { display: flex; align-items: center; gap: 0.875rem; }
  .author-avatar {
    width: 3rem; height: 3rem;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border);
  }
  .author-name {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--text-primary);
    font-weight: 500;
  }
  .author-handle {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }
  .author-bio {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  .author-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .author-socials a {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    text-transform: lowercase;
    color: var(--text-secondary);
  }
  .author-socials a:hover { color: var(--accent); }

  .footer-col h4 {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
  .footer-col a {
    font-family: var(--sans);
    font-weight: 300;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  .footer-col a:hover { color: var(--accent); }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }
  .footer-bottom a { color: var(--text-muted); }
  .footer-bottom a:hover { color: var(--accent); }

  @media (max-width: 768px) {
    .site-footer { padding: var(--space-lg) 1.25rem var(--space-md); }
  }
</style>

</body>
</html>
