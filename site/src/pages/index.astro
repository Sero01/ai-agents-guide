const LEARN_PATHS = [
  {
    label: 'Beginner',
    tag: 'start here',
    description: 'Set up Python, understand what an agent actually is, write your first ReAct loop in under fifty lines.',
    links: [
      { label: 'Getting Started', href: '/getting-started/' },
      { label: 'AI Agents', href: '/ai-agents/' },
